# Build the package with the canonical toolchain (node + tsc) ...
FROM node:24-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm clean-install
COPY . .
RUN npm run dist

# ... then run the bun:test matchers (source) and the smoke (built artifact) on
# bun. The whole tree — including node_modules (mongodb, bignumber.js) — is
# carried over so the dist artifact can resolve its runtime imports.
FROM oven/bun:1
WORKDIR /app
COPY --from=build /app /app
